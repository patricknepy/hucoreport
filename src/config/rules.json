{
  "version": "1.0",
  "description": "Règles d'identification intelligente des cellules Excel pour Huco Report",
  "rules": {
    "deadline": {
      "keywords": ["deadline", "date limite", "échéance", "due date"],
      "column_pattern": "C",
      "format": "date"
    },
    "status": {
      "keywords": ["status", "statut", "état", "state"],
      "column_pattern": "D",
      "format": "text",
      "valid_values": ["En cours", "Terminé", "En attente", "Bloqué"]
    },
    "responsible": {
      "keywords": ["responsable", "owner", "assigné", "assigned"],
      "column_pattern": "E",
      "format": "text"
    },
    "priority": {
      "keywords": ["priorité", "priority", "importance"],
      "column_pattern": "F",
      "format": "text",
      "valid_values": ["Haute", "Moyenne", "Basse"]
    },
    "project": {
      "keywords": ["projet", "project", "tâche", "task"],
      "column_pattern": "A",
      "format": "text"
    },
    "description": {
      "keywords": ["description", "détails", "details"],
      "column_pattern": "B",
      "format": "text"
    }
  },
  "detection_settings": {
    "header_row": 1,
    "case_sensitive": false,
    "partial_match": true
  }
}

